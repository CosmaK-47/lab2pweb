---
import "../styles/style.css";
import "../styles/reset.css";
import site from "../content/site.json";
import data from "../content/site.json";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HOM Cafe • Landing</title>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700;900&display=swap" rel="stylesheet">
   <!-- <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"> -->
<body>

<!-- HEADER -->
<header class="site-header" id="home">
  <div class="container header-inner">

    <!-- LOGO CENTERED -->
    <a class="brand" href="#home" aria-label="Home">
      <img class="brand-logo" src="/assets/logocafeniu.png" alt="HOM Cafe logo">
    </a>


    <!-- NAVIGATION -->
    <nav class="nav">
      <a class="nav-link" href="#home">Home</a>
      <a class="nav-link" href="#menu">Menu</a>
      <a class="nav-link" href="#schedule">Location</a>
      <a href={data.cateringLink} target="_blank">
        Catering
      </a>
      <a class="nav-link" href="#about">About</a>
      <a class="nav-link" href="#contact">Contact</a>
    </nav>
  </div>
</header>

    <a class="floating-contact" href="#contact" aria-label="Contact HOM Cafe">
    Contact
    </a>


<!-- HERO -->
<main>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-left">
        <p class="hero-kicker">{site.hero.kicker}</p>
        <h1 class="hero-title">{site.hero.title}</h1>

        <div class="hero-line"></div>

        <h2 class="hero-subtitle">{site.hero.subtitle}</h2>

        <p class="hero-text">{site.hero.text}</p>

        <div class="hero-actions">
<!--          <a class="btn ghost" href="#contact">Customize</a>-->
        </div>
      </div>

      <div class="hero-right" aria-hidden="true">
        <!-- Use your own image if you want; placeholder works too -->
        <img class="hero-truck" src="/assets/rulotaweb.png" alt="">
      </div>
    </div>
  </section>

  <!-- DAILY SPECIALS -->
  <section class="specials" id="specials">
    <div class="container specials-grid">
      {site.specials.items.map((item) => (
          <div class="special-card">
            <img src={item.image} alt={item.alt} />
            <h3>{item.name}</h3>
          </div>
      ))}

      <div class="specials-right">
        <h2 class="section-title big">{site.specials.title}</h2>
        <div class="section-line"></div>
        <p class="section-text">{site.specials.text}</p>
      </div>
    </div>
  </section>

  <!-- MENU -->
  <section class="menu" id="menu">
    <div class="container">
      <h2 class="section-title center">{site.menuIntro.title}</h2>
      <div class="section-line center-line"></div>
      <p class="elegant-text center">{site.menuIntro.text}</p>

      <div class="menu-grid">
        {site.menuSections.map((section) => (
            <div class={`menu-col ${section.title.toLowerCase() === "cafea" ? "coffee-col" :
                section.title.toLowerCase().includes("calde") ? "hot-col" :
                section.title.toLowerCase().includes("reci") ? "cold-col" :""}`}>
              <div class="menu-col-head">
                <h3>{section.title}</h3>
                <div class="menu-col-line"></div>
              </div>

              {section.items.map((item) => (
                  <div class="menu-item">
                    {item.image && <img src={item.image} alt={item.alt || item.name} />}
                    <div class="menu-item-meta">
                      <div class="menu-item-title">{item.name}</div>
                    </div>
                  </div>
              ))}
            </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCATION & SCHEDULE -->
  <section class="schedule" id="schedule">
    <div class="container">
      <h2 class="section-title big">Locație &amp;<br>Evenimente</h2>
      <div class="section-line"></div>

      <div class="map-wrap">
        <iframe
          title="Map"
          src="https://www.google.com/maps?q=Strada%20Nationala%2022,%20Ungheni,%20Moldova&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

      <div class="schedule-grid">
        {site.schedule.events.map((event) => (
            <div class="schedule-card">
              <div class="schedule-date">{event.date}</div>
              <div class="schedule-place">{event.city}</div>
              <div class="schedule-meta">
                <span>{event.location}</span>
                <span>{event.hours}</span>
              </div>
            </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div class="container about-grid">
      <div class="about-photo" aria-hidden="true">
        <img class="about-main" src={site.about.image} alt={site.about.imageAlt} />
        <img src="/assets/hom.png" class="about-signature" alt="HOM signature" />
      </div>

      <div class="about-content">
        <h2 class="section-title big">{site.about.title}</h2>
        <div class="section-line"></div>

        <h3 class="about-headline">{site.about.headline}</h3>

        <p class="section-text about-text">{site.about.text}</p>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">
    <div class="container contact-grid">
      <div>
        <h2 class="section-title big">{site.contact.title}</h2>
        <div class="section-line"></div>
        <p class="contact-text">{site.contact.text}</p>

        <div class="contact-mini">
          <div><strong>{site.contact.phoneLabel}</strong><span>{site.contact.phone}</span></div>
          <div><strong>{site.contact.emailLabel}</strong><span>{site.contact.email}</span></div>
        </div>
      </div>

      <form class="form">
        <div class="form-row">
          <input type="text" placeholder="Nume" required>
          <input type="text" placeholder="Prenume" required>
        </div>
        <input type="email" placeholder="Adresa de Email📧" required>
        <textarea rows="7" placeholder="Lasă-ne un mesaj 🥰"></textarea>
        <button class="btn accent" type="submit">{site.contact.button}</button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <p class="footer-title">{site.footer.title}</p>
      <p class="footer-text">{site.footer.text}</p>
      <div class="social">
        <a href={site.social.facebook}
           target="_blank"
           rel="noopener noreferrer"
           aria-label="Facebook">f</a>

        <a href={site.social.instagram}
           target="_blank"
           rel="noopener noreferrer"
           aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
              <path d="M7 2C4.2 2 2 4.2 2 7v10c0 2.8 2.2 5 5 5h10c2.8 0 5-2.2 5-5V7c0-2.8-2.2-5-5-5H7zm0 2h10c1.7 0 3 1.3 3 3v10c0 1.7-1.3 3-3 3H7c-1.7 0-3-1.3-3-3V7c0-1.7 1.3-3 3-3zm5 3.2A4.8 4.8 0 1 0 16.8 12 4.8 4.8 0 0 0 12 7.2zm0 2A2.8 2.8 0 1 1 9.2 12 2.8 2.8 0 0 1 12 9.2zm4.5-2.3a1 1 0 1 0 1 1 1 1 0 0 0-1-1z"/>
            </svg>
        </a>

        <a href={site.social.youtube}
           target="_blank"
           rel="noopener noreferrer"
           aria-label="YouTube">▶</a>
      </div>
      <p class="footer-copy">{site.footer.copy}</p>
    </div>
  </footer>
  <div class="mascot" aria-label="HOM Cafe mascot">
    <div class="mascot-bubble">{site.mascot.bubble}</div>

    <!-- simple friendly SVG mascot (coffee cup) -->
    <svg class="mascot-svg" viewBox="0 0 120 120" role="img" aria-label="Coffee mascot">
      <circle cx="60" cy="60" r="52" fill="rgba(247,241,227,.85)" stroke="rgba(111,78,55,.35)" stroke-width="4"/>
      <path d="M35 52h44v20c0 12-10 22-22 22S35 84 35 72V52z" fill="rgba(111,78,55,.85)"/>
      <path d="M79 56h10c8 0 8 20 0 20H79" fill="none" stroke="rgba(111,78,55,.85)" stroke-width="6" stroke-linecap="round"/>
      <circle cx="52" cy="67" r="4" fill="rgba(247,241,227,.95)"/>
      <circle cx="66" cy="67" r="4" fill="rgba(247,241,227,.95)"/>
      <path d="M52 78c4 4 12 4 16 0" fill="none" stroke="rgba(247,241,227,.95)" stroke-width="4" stroke-linecap="round"/>
      <path d="M46 44c-6-8 4-14 0-22" fill="none" stroke="rgba(122,31,43,.75)" stroke-width="4" stroke-linecap="round"/>
      <path d="M60 44c-6-8 4-14 0-22" fill="none" stroke="rgba(122,31,43,.75)" stroke-width="4" stroke-linecap="round"/>
      <path d="M74 44c-6-8 4-14 0-22" fill="none" stroke="rgba(122,31,43,.75)" stroke-width="4" stroke-linecap="round"/>
    </svg>
  </div>
  <script is:inline src="/js/script.js"></script>
  <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", function (user) {
        if (!user) {
          window.netlifyIdentity.on("login", function () {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</main>


</body>
</html>
